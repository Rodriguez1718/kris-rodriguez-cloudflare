---
import "../styles/theme.css";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: "website" | "article";
}

const { title, description, image, type = "website" } = Astro.props;

const siteTitle = "KRIS.";
const siteTagline = "Design & Development";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const siteDescription = description || siteTagline;

const navLinks = [
	{ label: "Work", url: "/work", num: "01" },
	{ label: "About", url: "/#about", num: "02" },
	{ label: "Contact", url: "/#contact", num: "03" },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<meta name="description" content={siteDescription} />
		<link rel="icon" type="image/png" href="/KRIS.png" />
		{image && <meta property="og:image" content={image} />}
		<meta property="og:type" content={type} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={siteDescription} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Anton&family=Allura&family=Playfair+Display:ital,wght@0,400..700;1,400..700&family=Syne:wght@400..800&family=Space+Mono:wght@700&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${siteTitle} RSS Feed`}
			href="/rss.xml"
		/>
	</head>
	<body>
		<!-- Custom Cursor -->
		<div class="cursor-dot" id="cursorDot"></div>
		<div class="cursor-brackets" id="cursorBrackets">
			<span class="bracket tl"></span>
			<span class="bracket tr"></span>
			<span class="bracket bl"></span>
			<span class="bracket br"></span>
		</div>

		<!-- Page Loader -->
		<div class="page-loader" id="pageLoader">
			<div class="loader-grid" id="gridLines"></div>
			<div class="loader-content">
				<div class="loader-number" id="loaderNumber">0%</div>
			</div>
		</div>

		<!-- Top Bar -->
		<header class="site-header">
			<nav class="nav">
				<a href="/" class="site-title">{siteTitle}</a>
				<div class="nav-actions">
					<button class="scroll-toggle-btn" id="scrollToggleBtn" aria-label="Toggle scroll mode" title="Toggle scroll animations">
						<span class="scroll-toggle-icon" id="scrollToggleIcon">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
								<polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
								<line x1="12" y1="22.08" x2="12" y2="12"></line>
							</svg>
						</span>
					</button>
					<div class="magnetic-zone">
						<button class="menu-btn" id="menuBtn" aria-label="Open menu">
							<span class="menu-btn-label" id="menuLabel">Menu</span>
							<span class="menu-btn-icon" id="menuIcon">
								<span></span>
								<span></span>
							</span>
						</button>
					</div>
				</div>
			</nav>
		</header>

		<!-- Fullscreen Menu Overlay -->
		<div class="menu-overlay" id="menuOverlay">
			<div class="menu-overlay-inner">
				<nav class="menu-nav">
					{navLinks.map((item) => (
						<a href={item.url} class="menu-nav-item" data-num={item.num}>
							<span class="menu-nav-num">{item.num}</span>
							<span class="menu-nav-label">{item.label}</span>
						</a>
					))}
				</nav>
				<div class="menu-footer">
					<span class="menu-tagline">{siteTagline}</span>
					<a href="/_emdash/admin" target="_blank" rel="noopener noreferrer" class="menu-admin">Admin</a>
				</div>
			</div>
		</div>

		<main>
			<slot />
		</main>

		<button class="chat-button" id="chatButton" aria-label="Open chat">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
			</svg>
		</button>

		<footer class="site-footer">
			<div class="footer-content">
				<!-- Top row -->
				<div class="footer-top">
					<div class="footer-top-left">
						<div class="footer-availability">
							<span class="availability-dot"></span>
							<span>Available for work</span>
						</div>
						<p class="footer-tagline">Designing & engineering<br/>exceptional digital experiences.</p>
					</div>
					<div class="footer-top-right">
						<div class="footer-location">
							<span class="footer-meta-label">Based in</span>
							<span class="footer-meta-value">Cebu, Philippines</span>
						</div>
						<div class="footer-timezone">
							<span class="footer-meta-label">Timezone</span>
							<span class="footer-meta-value" id="footerTime">PHT UTC+8</span>
						</div>
					</div>
				</div>

				<!-- Bottom row -->
				<div class="footer-bottom">
					<div class="footer-left">
						<p class="footer-copyright">© 2026 {siteTitle}. All rights reserved.</p>
					</div>
					<div class="footer-center">
						<a href="mailto:contact@example.com" class="footer-link footer-social">
							<span class="footer-social-label">Email</span>
							<span class="footer-social-arrow">↗</span>
						</a>
						<a href="https://github.com" target="_blank" class="footer-link footer-social">
							<span class="footer-social-label">GitHub</span>
							<span class="footer-social-arrow">↗</span>
						</a>
						<a href="https://linkedin.com" target="_blank" class="footer-link footer-social">
							<span class="footer-social-label">LinkedIn</span>
							<span class="footer-social-arrow">↗</span>
						</a>
					</div>
					<div class="footer-right">
						<div class="magnetic-zone">
							<a href="/Rodriguez_CV.pdf" download class="footer-cv-btn">
								<span>Download CV</span>
								<span class="cv-arrow">↓</span>
							</a>
						</div>
					</div>
				</div>

				<!-- Big name -->
				<div class="footer-hero">
					<h2 class="footer-name">RODRIGUEZ</h2>
				</div>

			</div>
		</footer>

		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				// ── Scroll Mode Toggle ──
				const scrollToggleBtn = document.getElementById('scrollToggleBtn');
				const scrollToggleIcon = document.getElementById('scrollToggleIcon');
				
				// Check saved preference or default to animated
				let isSimpleScroll = localStorage.getItem('simpleScrollMode') === 'true';
				
				// Apply initial state
				const applyScrollMode = () => {
					if (isSimpleScroll) {
						document.body.classList.add('simple-scroll');
						scrollToggleBtn?.classList.add('is-simple');
					} else {
						document.body.classList.remove('simple-scroll');
						scrollToggleBtn?.classList.remove('is-simple');
					}
				};
				
				applyScrollMode();
				
				// Toggle handler
				scrollToggleBtn?.addEventListener('click', () => {
					isSimpleScroll = !isSimpleScroll;
					localStorage.setItem('simpleScrollMode', isSimpleScroll.toString());
					applyScrollMode();
					
					// Reload page to reinitialize scripts with new mode
					window.location.reload();
				});

				// ── Page Loader ──
				const loader = document.getElementById('pageLoader');
				const loaderNumber = document.getElementById('loaderNumber');
				const gridLines = document.getElementById('gridLines');
				const gridCount = 28;
				const lines = [];

				if (gridLines) {
					const W = window.innerWidth;
					const center = W / 2;

					for (let i = 0; i < gridCount; i++) {
						const line = document.createElement('div');
						line.className = 'grid-line';
						const x = (i / (gridCount - 1)) * W;
						line.style.left = x + 'px';
						gridLines.appendChild(line);
						lines.push({ el: line, x });
					}

					let progress = 0;

					const interval = setInterval(() => {
						progress += Math.random() * 5 + 2;
						if (progress > 100) progress = 100;

						if (loaderNumber) {
							loaderNumber.textContent = Math.floor(progress) + '%';
						}

						const scaleY = 0.05 + (progress / 100) * 0.95;
						lines.forEach(({ el }) => {
							el.style.transition = 'none';
							el.style.transform = `scaleY(${scaleY})`;
						});

						if (progress >= 100) {
							clearInterval(interval);

							setTimeout(() => {
								if (loaderNumber) {
									loaderNumber.style.transform = 'translateY(120px)';
									loaderNumber.style.opacity = '0';
								}
							}, 200);

							setTimeout(() => {
								lines.forEach(({ el, x }) => {
									const dist = x - center;
									el.style.transition = 'transform 0.7s cubic-bezier(0.76,0,0.24,1)';
									el.style.transform = `translateX(${-dist}px) scaleY(1)`;
								});
							}, 500);

							setTimeout(() => {
								lines.forEach(({ el }) => {
									el.style.display = 'none';
								});

								loader.style.background = 'transparent';

								const left = document.createElement('div');
								const right = document.createElement('div');
								const shared = `
									position: absolute; top: 0; height: 100%;
									width: 50%; background: var(--color-bg);
									transition: transform 0.7s cubic-bezier(0.76,0,0.24,1);
								`;
								left.style.cssText = shared + 'left: 0;';
								right.style.cssText = shared + 'right: 0;';
								loader.appendChild(left);
								loader.appendChild(right);

								left.getBoundingClientRect();
								left.style.transform = 'translateX(-100%)';
								right.style.transform = 'translateX(100%)';

								setTimeout(() => {
									loader?.classList.add('loaded');
								}, 700);
							}, 1300);
						}
					}, 110);
				}

				// ── Menu Toggle ──
				const menuBtn = document.getElementById('menuBtn');
				const menuOverlay = document.getElementById('menuOverlay');
				const menuLabel = document.getElementById('menuLabel');

				let menuOpen = false;

				menuBtn?.addEventListener('click', () => {
					menuOpen = !menuOpen;
					menuOverlay?.classList.toggle('is-open', menuOpen);
					menuBtn?.classList.toggle('is-open', menuOpen);
					if (menuLabel) menuLabel.textContent = menuOpen ? 'Close' : 'Menu';
					document.body.style.overflow = menuOpen ? 'hidden' : '';
				});

				document.querySelectorAll('.menu-nav-item').forEach(link => {
					link.addEventListener('click', () => {
						menuOpen = false;
						menuOverlay?.classList.remove('is-open');
						menuBtn?.classList.remove('is-open');
						if (menuLabel) menuLabel.textContent = 'Menu';
						document.body.style.overflow = '';
					});
				});

				// ── Magnetic Menu Button ──
				const magneticZone = document.querySelector('.site-header .magnetic-zone');
				const btn = magneticZone?.querySelector('.menu-btn');
				const strength = 0.35;

				if (magneticZone && btn) {
					let rect = null;

					magneticZone.addEventListener('pointerenter', () => {
						rect = magneticZone.getBoundingClientRect();
					});

					magneticZone.addEventListener('mousemove', (e) => {
						const currentRect = rect || magneticZone.getBoundingClientRect();
						rect = currentRect;
						const x = ((e.clientX - currentRect.left) / currentRect.width - 0.5) * currentRect.width;
						const y = ((e.clientY - currentRect.top) / currentRect.height - 0.5) * currentRect.height;

						btn.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
						btn.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
					});

					magneticZone.addEventListener('mouseleave', () => {
						rect = null;
						btn.style.transform = 'translate(0, 0)';
						btn.style.transition = 'transform 0.7s cubic-bezier(0.16, 1, 0.3, 1)';
					});
				}

				// ── Magnetic CV Button ──
				const cvMagneticZone = document.querySelector('.footer-right .magnetic-zone');
				const cvBtn = cvMagneticZone?.querySelector('.footer-cv-btn');

				if (cvMagneticZone && cvBtn) {
					let cvRect = null;

					cvMagneticZone.addEventListener('pointerenter', () => {
						cvRect = cvMagneticZone.getBoundingClientRect();
					});

					cvMagneticZone.addEventListener('mousemove', (e) => {
						const currentRect = cvRect || cvMagneticZone.getBoundingClientRect();
						cvRect = currentRect;
						const x = ((e.clientX - currentRect.left) / currentRect.width - 0.5) * currentRect.width;
						const y = ((e.clientY - currentRect.top) / currentRect.height - 0.5) * currentRect.height;

						cvBtn.style.transform = `translate(${x * strength}px, ${y * strength}px)`;
						cvBtn.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
					});

					cvMagneticZone.addEventListener('mouseleave', () => {
						cvRect = null;
						cvBtn.style.transform = 'translate(0, 0)';
						cvBtn.style.transition = 'transform 0.7s cubic-bezier(0.16, 1, 0.3, 1)';
					});
				}

				// Live footer time
				const footerTime = document.getElementById('footerTime');
				if (footerTime) {
					const updateTime = () => {
						const now = new Date();
						const time = now.toLocaleTimeString('en-US', {
							timeZone: 'Asia/Manila',
							hour: '2-digit',
							minute: '2-digit',
							hour12: true
						});
						footerTime.textContent = `PHT ${time}`;
					};
					updateTime();
					setInterval(updateTime, 1000);
				}
			});
		</script>

		<script is:inline>
			// ── Custom Magnetic Cursor ──
			(function() {
				const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
				if (isTouchDevice || window.innerWidth < 768) return;

				const dot = document.getElementById('cursorDot');
				const brackets = document.getElementById('cursorBrackets');
				if (!dot || !brackets) return;

				let mouseX = 0, mouseY = 0;
				let dotX = 0, dotY = 0;
				let bracketsX = 0, bracketsY = 0;
				let hoveredEl = null;
				let isHovering = false;

				document.addEventListener('mousemove', (e) => {
					mouseX = e.clientX;
					mouseY = e.clientY;
				});

				function animate() {
					if (isHovering && hoveredEl) {
						const rect = hoveredEl.getBoundingClientRect();
						const targetX = rect.left + rect.width / 2;
						const targetY = rect.top + rect.height / 2;
						const bw = rect.width + 16;
						const bh = rect.height + 16;

						dotX += (mouseX - dotX) * 0.15;
						dotY += (mouseY - dotY) * 0.15;

						bracketsX += (targetX - bracketsX) * 0.12;
						bracketsY += (targetY - bracketsY) * 0.12;

						brackets.style.left = (bracketsX - bw / 2) + 'px';
						brackets.style.top = (bracketsY - bh / 2) + 'px';
						brackets.style.width = bw + 'px';
						brackets.style.height = bh + 'px';
					} else {
						dotX += (mouseX - dotX) * 0.2;
						dotY += (mouseY - dotY) * 0.2;

						bracketsX = dotX;
						bracketsY = dotY;

						brackets.style.left = (bracketsX - 14) + 'px';
						brackets.style.top = (bracketsY - 14) + 'px';
						brackets.style.width = '28px';
						brackets.style.height = '28px';
					}

					dot.style.left = dotX + 'px';
					dot.style.top = dotY + 'px';

					requestAnimationFrame(animate);
				}
				animate();

				const hoverTargets = 'a, button, [role="button"], .skill-row, .contact-row, .timeline-card-wrapper, .project-card, .card-link, .menu-nav-item';

				document.addEventListener('mouseover', (e) => {
					const target = e.target.closest(hoverTargets);
					if (target) {
						hoveredEl = target;
						isHovering = true;
						brackets.classList.add('hovering');
					}
				});

				document.addEventListener('mouseout', (e) => {
					const target = e.target.closest(hoverTargets);
					if (target) {
						hoveredEl = null;
						isHovering = false;
						brackets.classList.remove('hovering');
					}
				});

				document.addEventListener('mouseleave', () => {
					dot.style.opacity = '0';
					brackets.style.opacity = '0';
				});

				document.addEventListener('mouseenter', () => {
					dot.style.opacity = '1';
					brackets.style.opacity = '1';
				});
			})();
		</script>

		<script type="module">
			import Chatbot from "https://cdn.jsdelivr.net/npm/flowise-embed/dist/web.js"
			Chatbot.init({
				chatflowid: "04cfc748-8fec-4eb6-b288-0d800414332b",
				apiHost: "https://cloud.flowiseai.com",
				theme: {
					button: {
						backgroundColor: "transparent",
						right: 20,
						bottom: 20,
						size: "medium",
						iconColor: "white",
						customIconSrc: "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none'%3E%3C/svg%3E"
					},
					chatWindow: {
						showAgentMessages: true
					}
				}
			})

			document.addEventListener('DOMContentLoaded', () => {
				// Give Flowise a moment to render its shadow DOM
				setTimeout(() => {
					const flowiseEl = document.querySelector('flowise-chatbot')

					// Hide the default Flowise button inside shadow DOM
					const shadowBtn = flowiseEl?.shadowRoot?.querySelector('button')
					if (shadowBtn) {
						shadowBtn.style.display = 'none'
					}

					// Your button now does the toggling
					document.getElementById('chatButton').addEventListener('click', () => {
						flowiseEl?.shadowRoot?.querySelector('button')?.click()
					})
				}, 500)
			})
		</script>


		<style is:global>
			@layer base;

			@layer base {
				*,
				*::before,
				*::after {
					box-sizing: border-box;
					margin: 0;
					padding: 0;
				}

				:root {
					--color-bg: #0a0a0a;
					--color-text: #f5f5f5;
					--color-muted: #a1a1aa;
					--color-border: #27272a;
					--color-surface: #18181b;
					--color-accent: #a78bfa;
					--color-accent-muted: #7c3aed;

					--font-sans: system-ui, -apple-system, sans-serif;
					--font-mono: ui-monospace, monospace;

					--font-size-sm: 0.875rem;
					--font-size-base: 1.0625rem;
					--font-size-lg: 1.25rem;
					--font-size-xl: 1.5rem;
					--font-size-2xl: 2rem;
					--font-size-3xl: 2.75rem;
					--font-size-4xl: 3.5rem;

					--spacing-xs: 0.25rem;
					--spacing-sm: 0.5rem;
					--spacing-md: 1rem;
					--spacing-lg: 1.5rem;
					--spacing-xl: 2rem;
					--spacing-2xl: 3rem;
					--spacing-3xl: 4rem;
					--spacing-4xl: 6rem;

					--max-width: 720px;
					--wide-width: 1200px;
					--radius: 4px;

					--transition-fast: 150ms ease;
					--transition-base: 200ms ease;
					--transition-slow: 300ms ease;
				}

				html {
					scroll-behavior: smooth;
					overflow-x: clip;
					max-width: 100vw;
				}

				body {
					font-family: var(--font-sans);
					font-size: var(--font-size-base);
					line-height: 1.6;
					color: var(--color-text);
					background: var(--color-bg);
					-webkit-font-smoothing: antialiased;
					min-height: 100vh;
					overflow-x: clip;
					max-width: 100vw;
					position: relative;
				}

				a { color: currentColor; }

				img {
					max-width: 100%;
					height: auto;
					display: block;
				}

				h1, h2, h3, h4 {
					font-family: var(--font-serif);
					font-weight: 500;
					line-height: 1.2;
				}

				h1 { font-size: var(--font-size-4xl); }
				h2 { font-size: var(--font-size-2xl); }
				h3 { font-size: var(--font-size-xl); }
			}
		</style>

		<style is:global>
			/* ── Custom Cursor ── */
			.cursor-dot {
				position: fixed;
				top: 0;
				left: 0;
				width: 6px;
				height: 6px;
				background: #fff;
				border-radius: 50%;
				pointer-events: none;
				z-index: 99999;
				transform: translate(-50%, -50%);
				transition: opacity 0.3s ease;
				mix-blend-mode: difference;
			}

			.cursor-brackets {
				position: fixed;
				top: 0;
				left: 0;
				width: 28px;
				height: 28px;
				pointer-events: none;
				z-index: 99998;
				animation: cursor-spin 4s linear infinite;
				transition: width 0.4s cubic-bezier(0.16,1,0.3,1), height 0.4s cubic-bezier(0.16,1,0.3,1);
				mix-blend-mode: difference;
			}

			.cursor-brackets.hovering {
				animation: none;
				border-radius: 0;
			}

			@keyframes cursor-spin {
				from { rotate: 0deg; }
				to { rotate: 360deg; }
			}

			.bracket {
				position: absolute;
				width: 8px;
				height: 8px;
				border-color: #fff;
				border-style: solid;
				border-width: 0;
				transition: width 0.4s cubic-bezier(0.16,1,0.3,1), height 0.4s cubic-bezier(0.16,1,0.3,1);
			}

			.bracket.tl {
				top: 0; left: 0;
				border-top-width: 2px;
				border-left-width: 2px;
			}
			.bracket.tr {
				top: 0; right: 0;
				border-top-width: 2px;
				border-right-width: 2px;
			}
			.bracket.bl {
				bottom: 0; left: 0;
				border-bottom-width: 2px;
				border-left-width: 2px;
			}
			.bracket.br {
				bottom: 0; right: 0;
				border-bottom-width: 2px;
				border-right-width: 2px;
			}

			/* ── Chat Button ── */
			.chat-button {
				position: fixed;
				bottom: var(--spacing-xl);
				right: var(--spacing-xl);
				width: 60px;
				height: 60px;
				border-radius: 50%;
				background: var(--color-text);
				color: var(--color-bg);
				border: 1px solid var(--color-text);
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				z-index: 1000;
				transition: all 0.3s ease;
			}

			.chat-button:hover {
				background: var(--color-bg);
				color: var(--color-text);
				transform: scale(1.1);
			}

			.chat-button svg {
				width: 24px;
				height: 24px;
			}

			/* Hide Flowise's own button, keep only ours */
			.flowise-chatbot::part(button),
			.flowise-chatbot > div > button {
				display: none !important;
			}

			@media (max-width: 768px) {
				.chat-button {
					width: 50px;
					height: 50px;
					bottom: var(--spacing-md);
					right: var(--spacing-md);
				}
			}


			/* Hide on mobile/touch */
			@media (max-width: 768px), (hover: none) {
				.cursor-dot, .cursor-brackets { display: none !important; }
			}

			/* Hide default cursor on desktop */
			@media (hover: hover) {
				*, *::before, *::after { cursor: none !important; }
			}

			/* ── Simple Scroll Mode ── */
			body.simple-scroll .pin-spacer {
				display: block !important;
				height: auto !important;
				padding: 0 !important;
				position: static !important;
			}

			body.simple-scroll .pin-spacer > * {
				position: static !important;
				transform: none !important;
			}

			body.simple-scroll .hero {
				height: auto !important;
				min-height: 50vh !important;
				padding: var(--spacing-4xl) var(--spacing-lg) !important;
				position: relative !important;
			}

			body.simple-scroll .hero-inner {
				transform: none !important;
				scale: 1 !important;
			}

			body.simple-scroll .hero-content {
				padding: var(--spacing-2xl) var(--spacing-lg) !important;
			}

			body.simple-scroll .title-word,
			body.simple-scroll .normal-letter,
			body.simple-scroll .zoom-letter,
			body.simple-scroll .subtitle-container,
			body.simple-scroll .topo-bg {
				opacity: 1 !important;
				transform: none !important;
				animation: none !important;
			}

			body.simple-scroll .horizontal-scroll-container {
				height: auto !important;
				overflow: visible !important;
				position: relative !important;
			}

			body.simple-scroll .horizontal-track {
				width: 100% !important;
				height: auto !important;
				flex-direction: column !important;
				transform: none !important;
				display: flex !important;
			}

			body.simple-scroll .motion-path-container {
				display: none !important;
			}

			body.simple-scroll .about,
			body.simple-scroll .skills {
				width: 100% !important;
				height: auto !important;
				min-height: auto !important;
				padding: var(--spacing-4xl) var(--spacing-lg) !important;
				flex-shrink: 0 !important;
			}

			body.simple-scroll .about-container,
			body.simple-scroll .skills-container {
				max-width: var(--wide-width) !important;
				margin: 0 auto !important;
			}

			body.simple-scroll .about-number,
			body.simple-scroll .about-heading,
			body.simple-scroll .about-badge,
			body.simple-scroll .about-content > *,
			body.simple-scroll .skills-number,
			body.simple-scroll .skills-heading,
			body.simple-scroll .skills-intro,
			body.simple-scroll .skill-row {
				opacity: 1 !important;
				transform: none !important;
			}

			/* ── Loader ── */
			.page-loader {
				position: fixed;
				top: 0;
				left: 0;
				width: 100vw;
				height: 100vh;
				background: var(--color-bg);
				z-index: 9999;
			}

			.page-loader.loaded {
				display: none;
			}

			.loader-grid {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
			}

			.grid-line {
				position: absolute;
				top: 0;
				width: 1px;
				height: 100%;
				background: rgba(255, 255, 255, 0.18);
				transform: scaleY(0.05);
				transform-origin: center;
			}

			.loader-content {
				position: fixed;
				bottom: var(--spacing-2xl);
				right: var(--spacing-2xl);
				z-index: 10;
			}

			.loader-number {
				font-family: 'Anton', sans-serif;
				font-size: clamp(3rem, 10vw, 8rem);
				font-weight: 700;
				color: var(--color-text);
				letter-spacing: 0.05em;
				line-height: 1;
				transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
			}

			/* ── Header ── */
			.site-header {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				width: 100%;
				padding: var(--spacing-xl) var(--spacing-xl);
				z-index: 1000;
				mix-blend-mode: difference;
			}

			.nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.nav-actions {
				display: flex;
				align-items: center;
				gap: var(--spacing-md);
			}

			.site-title {
				font-family: "Syne", sans-serif;
				font-size: var(--font-size-sm);
				font-weight: 800;
				text-decoration: none;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-text);
			}

			/* ── Scroll Toggle Button ── */
			.scroll-toggle-btn {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 36px;
				height: 36px;
				background: none;
				border: 1px solid var(--color-text);
				color: var(--color-text);
				border-radius: 50%;
				padding: 0;
				transition: all 0.3s ease;
				cursor: pointer;
			}

			.scroll-toggle-btn:hover {
				background: var(--color-text);
				color: var(--color-bg);
				transform: rotate(180deg);
			}

			.scroll-toggle-btn.is-simple {
				background: var(--color-text);
				color: var(--color-bg);
			}

			.scroll-toggle-btn.is-simple:hover {
				background: none;
				color: var(--color-text);
			}

			.scroll-toggle-icon {
				display: flex;
				align-items: center;
				justify-content: center;
			}

			.scroll-toggle-icon svg {
				transition: transform 0.3s ease;
			}

			.scroll-toggle-btn.is-simple .scroll-toggle-icon svg {
				transform: rotate(90deg);
			}

			/* ── Menu Button ── */
			.site-header .magnetic-zone {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 100px;
				height: 100px;
				border-radius: 50%;
				margin-top: -25px;
				margin-bottom: -25px;
			}

			.menu-btn {
				display: flex;
				align-items: center;
				gap: 10px;
				background: none;
				border: none;
				color: var(--color-text);
				padding: 0;
				will-change: transform;
			}

			.menu-btn-label {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--color-text);
			}

			.menu-btn-icon {
				display: flex;
				flex-direction: column;
				gap: 5px;
				width: 22px;
			}

			.menu-btn-icon span {
				display: block;
				width: 100%;
				height: 1px;
				background: var(--color-text);
				transition: transform 0.4s cubic-bezier(0.76,0,0.24,1), opacity 0.3s ease;
				transform-origin: center;
			}

			.menu-btn.is-open .menu-btn-icon span:first-child {
				transform: translateY(3px) rotate(45deg);
			}

			.menu-btn.is-open .menu-btn-icon span:last-child {
				transform: translateY(-3px) rotate(-45deg);
			}

			/* ── Menu Overlay ── */
			.menu-overlay {
				position: fixed;
				inset: 0;
				background: var(--color-bg);
				z-index: 999;
				display: flex;
				flex-direction: column;
				padding: var(--spacing-4xl) var(--spacing-xl) var(--spacing-2xl);
				clip-path: inset(0 0 100% 0);
				transition: clip-path 0.7s cubic-bezier(0.76,0,0.24,1);
			}

			.menu-overlay.is-open {
				clip-path: inset(0 0 0% 0);
			}

			.menu-overlay-inner {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				height: 100%;
			}

			.menu-nav {
				display: flex;
				flex-direction: column;
				margin-top: auto;
				padding-top: var(--spacing-2xl);
			}

			.menu-nav-item {
				display: flex;
				align-items: baseline;
				gap: var(--spacing-lg);
				text-decoration: none;
				color: var(--color-text);
				padding: var(--spacing-lg) 0;
				border-top: 1px solid var(--color-border);
				transition: color var(--transition-fast);
			}

			.menu-nav-item:last-child {
				border-bottom: 1px solid var(--color-border);
			}

			.menu-nav-item:hover {
				color: var(--color-muted);
			}

			.menu-nav-num {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				color: var(--color-muted);
				letter-spacing: 0.05em;
				flex-shrink: 0;
			}

			.menu-nav-label {
				font-family: "Syne", sans-serif;
				font-size: clamp(2.5rem, 8vw, 7rem);
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: -0.04em;
				line-height: 1;
				transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
			}

			.menu-nav-item:hover .menu-nav-label {
				transform: translateX(1rem);
			}

			.menu-footer {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				padding-top: var(--spacing-2xl);
			}

			.menu-tagline {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-muted);
			}

			.menu-admin {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-muted);
				text-decoration: none;
				opacity: 0.5;
				transition: opacity var(--transition-fast);
			}

			.menu-admin:hover {
				opacity: 1;
			}

			/* ── Main ── */
			main {
				min-height: 100vh;
				overflow-x: clip;
				max-width: 100vw;
				position: relative;
				z-index: 1;
				background: var(--color-bg);
			}

			/* ── Footer ── */
			.site-footer {
				width: 100%;
				padding: 0;
				border-top: 1px solid var(--color-border);
				position: sticky;
				bottom: 0;
				z-index: 0;
			}

			.footer-content {
				display: flex;
				flex-direction: column;
			}

			/* Top row */
			.footer-top {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				padding: var(--spacing-2xl) var(--spacing-lg);
				border-bottom: 1px solid var(--color-border);
				max-width: var(--wide-width);
				margin: 0 auto;
				width: 100%;
			}

			.footer-top-left {
				display: flex;
				flex-direction: column;
				gap: var(--spacing-lg);
			}

			.footer-availability {
				display: inline-flex;
				align-items: center;
				gap: var(--spacing-sm);
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: #4ade80;
				border: 1px solid rgba(74, 222, 128, 0.3);
				padding: var(--spacing-xs) var(--spacing-md);
				border-radius: 999px;
				width: fit-content;
			}

			.availability-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: #4ade80;
				animation: pulse-dot 2s ease-in-out infinite;
			}

			@keyframes pulse-dot {
				0%, 100% { opacity: 1; transform: scale(1); }
				50% { opacity: 0.5; transform: scale(0.8); }
			}

			.footer-tagline {
				font-family: "Syne", sans-serif;
				font-size: clamp(1rem, 2vw, 1.4rem);
				font-weight: 600;
				color: var(--color-muted);
				line-height: 1.4;
			}

			.footer-top-right {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: var(--spacing-lg);
			}

			.footer-location,
			.footer-timezone {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 2px;
			}

			.footer-meta-label {
				font-family: var(--font-mono);
				font-size: 0.65rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-muted);
				opacity: 0.6;
			}

			.footer-meta-value {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: var(--color-text);
			}

			/* Big name */
			.footer-hero {
				width: 100%;
				border-top: 1px solid var(--color-border);
				overflow: hidden;
				display: flex;
				align-items: flex-end;
				height: 160px; /* controls how much gets cut off */
			}

			.footer-name {
				font-family: "Syne", sans-serif;
				font-size: clamp(2rem, 9.5vw, 14rem);
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: -0.05em;
				line-height: 0.8;
				color: var(--color-text);
				margin: 0;
				padding: 0;
				white-space: nowrap;
				width: 100%;
				text-align: center;
			}

			/* Bottom row */
			.footer-bottom {
				display: grid;
				grid-template-columns: 1fr auto auto;
				align-items: center;
				gap: var(--spacing-2xl);
				max-width: var(--wide-width);
				margin: 0 auto;
				width: 100%;
				padding: var(--spacing-xl) var(--spacing-lg);
			}

			.footer-left {
				display: flex;
				justify-content: flex-start;
			}

			.footer-center {
				display: flex;
				justify-content: center;
				gap: var(--spacing-xl);
			}

			.footer-right {
				display: flex;
				justify-content: flex-end;
				margin-left: auto;
			}

			.footer-right .magnetic-zone {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				width: 120px;
				height: 60px;
				border-radius: 0;
			}

			.footer-social {
				display: inline-flex;
				align-items: center;
				gap: 4px;
				text-decoration: none;
				transition: color var(--transition-fast);
			}

			.footer-social-label {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: var(--color-muted);
				transition: color var(--transition-fast);
			}

			.footer-social-arrow {
				font-size: 0.65rem;
				color: var(--color-muted);
				opacity: 0;
				transform: translateY(2px);
				transition: all var(--transition-fast);
			}

			.footer-social:hover .footer-social-label {
				color: var(--color-text);
			}

			.footer-social:hover .footer-social-arrow {
				opacity: 1;
				transform: translateY(0);
			}

			.footer-copyright {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				color: var(--color-muted);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}

			.footer-cv-btn {
				display: inline-flex;
				align-items: center;
				gap: var(--spacing-md);
				padding: var(--spacing-md) var(--spacing-xl);
				border: 1px solid var(--color-text);
				background: transparent;
				color: var(--color-text);
				text-decoration: none;
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				transition: all 0.3s ease;
				white-space: nowrap;
				will-change: transform;
			}

			.footer-cv-btn:hover {
				background: var(--color-text);
				color: var(--color-bg);
			}

			.cv-arrow {
				transition: transform var(--transition-fast);
				font-size: 1.1rem;
				line-height: 1;
			}

			.footer-cv-btn:hover .cv-arrow {
				transform: translateY(4px);
			}

			@media (max-width: 640px) {
				.site-header {
					padding: var(--spacing-md) var(--spacing-md);
				}

				.nav-actions {
					gap: var(--spacing-sm);
				}

				.scroll-toggle-btn {
					width: 32px;
					height: 32px;
				}

				.scroll-toggle-icon svg {
					width: 16px;
					height: 16px;
				}

				.menu-overlay {
					padding: var(--spacing-3xl) var(--spacing-md) var(--spacing-xl);
				}

				.menu-nav {
					padding-top: var(--spacing-xl);
				}

				.menu-nav-item {
					padding: var(--spacing-md) 0;
					gap: var(--spacing-md);
				}

				.menu-nav-num {
					font-size: 0.6rem;
				}

				.menu-nav-label {
					font-size: clamp(1.75rem, 10vw, 3.5rem);
					letter-spacing: -0.02em;
				}

				.menu-footer {
					flex-direction: column;
					align-items: flex-start;
					gap: var(--spacing-md);
					padding-top: var(--spacing-xl);
				}

				.menu-tagline {
					font-size: 0.65rem;
				}

				.menu-admin {
					font-size: 0.65rem;
				}

				.site-footer {
					padding: 0 0 var(--spacing-3xl) 0;
				}

				.footer-content {
					gap: var(--spacing-2xl);
				}

				.footer-hero {
					padding: var(--spacing-2xl) var(--spacing-md) var(--spacing-xl) var(--spacing-md);
					gap: var(--spacing-xl);
				}

				.footer-name {
					font-size: clamp(1.75rem, 9.5vw, 4rem);
					transform: scaleY(1.4);
					letter-spacing: -0.03em;
				}

				.footer-top {
					flex-direction: column;
					gap: var(--spacing-xl);
					padding: var(--spacing-xl) var(--spacing-md);
				}

				.footer-top-right {
					align-items: flex-start;
					flex-direction: row;
					gap: var(--spacing-2xl);
				}

				.footer-location,
				.footer-timezone {
					align-items: flex-start;
				}

				.footer-bottom {
					display: flex;
					flex-direction: column;
					gap: var(--spacing-lg);
					padding: var(--spacing-lg) var(--spacing-md);
					text-align: center;
				}

				.footer-left {
					justify-content: center;
					order: 3;
				}

				.footer-center {
					justify-content: center;
					flex-wrap: wrap;
					order: 1;
				}

				.footer-right {
					justify-content: center;
					order: 2;
					width: 100%;
				}

				.footer-right .magnetic-zone {
					width: 100%;
					display: flex;
				}

				.footer-cv-btn {
					width: 100%;
					justify-content: center;
					padding: var(--spacing-md) var(--spacing-lg);
				}

				.footer-copyright {
					font-size: 0.65rem;
				}

				.footer-link {
					font-size: 0.65rem;
				}

				h1 {
					font-size: var(--font-size-3xl);
				}
			}
		</style>
	</body>
</html>