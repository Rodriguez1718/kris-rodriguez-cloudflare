---
import { getEmDashCollection } from "emdash";
import Base from "../layouts/Base.astro";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Skills from "../components/sections/Skills.astro";
import FeaturedWorks from "../components/sections/FeaturedWorks.astro";
import Experience from "../components/sections/Experience.astro";
import Contact from "../components/sections/Contact.astro";

// Fetch all data from EmDash
const [
	{ entries: allProjects, cacheHint: projectsCache },
	{ entries: skillsEntries, cacheHint: skillsCache },
	{ entries: experiencesEntries, cacheHint: experiencesCache },
	{ entries: contactsEntries, cacheHint: contactsCache },
	{ entries: aboutsEntries, cacheHint: aboutsCache },
] = await Promise.all([
	getEmDashCollection("projects", { orderBy: { created_at: "desc" } }),
	getEmDashCollection("skills", { orderBy: { created_at: "asc" } }),
	getEmDashCollection("experiences", { orderBy: { created_at: "desc" } }),
	getEmDashCollection("contacts", { orderBy: { created_at: "asc" } }),
	getEmDashCollection("abouts", { limit: 1 }),
]);

// Set Route Caching for Cloudflare
if (import.meta.env.PROD && Astro.cache?.enabled) {
	Astro.cache.set(projectsCache);
	Astro.cache.set(skillsCache);
	Astro.cache.set(experiencesCache);
	Astro.cache.set(contactsCache);
	Astro.cache.set(aboutsCache);
}

// Map entries to their raw data structure
const featuredProjects = allProjects.slice(0, 4);
const skills = skillsEntries.map(s => s.data);
const experiences = experiencesEntries.map(e => e.data);
const contacts = contactsEntries.map(c => c.data);
const about = aboutsEntries[0]?.data || null;
---

<Base>
	<Hero />

	<div class="horizontal-scroll-container">
		<div class="horizontal-track">
			<!-- Motion Path SVG wrapper (placed inside track to slide along horizontally!) -->
			<div class="motion-path-container">
				<svg
					class="motion-svg"
					viewBox="0 0 3840 1080"
					fill="none"
					xmlns="http://www.w3.org/2000/svg">
					<path
						id="flying-path"
						d="M 100 300 C 1000 100, 900 900, 1920 400 C 2900 -100, 2800 900, 3740 300"
						stroke="rgba(0,0,0,0.07)"
						stroke-width="3"
						stroke-dasharray="8 8"></path>
				</svg>
				<div class="flying-element">
					<svg
						width="40"
						height="40"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5">
						<path
							d="M12 2 L12 22 M2 12 L22 12 M5 5 L19 19 M5 19 L19 5"
							stroke="#000000"
							stroke-linecap="square"></path>
					</svg>
				</div>
			</div>

			<About content={about?.content} />
			<Skills skills={skills} />
		</div>
	</div>

	<FeaturedWorks projects={featuredProjects} />
	<Experience experiences={experiences} />
	<Contact contacts={contacts} />
</Base>

<style>
	.horizontal-scroll-container {
		width: 100%;
		height: 100vh;
		position: relative;
		overflow: hidden;
		background-color: #ffffff;
	}

	.motion-path-container {
		position: absolute;
		top: 0;
		left: 0;
		width: 200vw;
		height: 100%;
		pointer-events: none;
		z-index: 5;
	}

	.motion-svg {
		width: 100%;
		height: 100%;
		position: absolute;
		top: 0;
		left: 0;
	}

	.flying-element {
		position: absolute;
		top: 0;
		left: 0;
		width: 40px;
		height: 40px;
		transform: translate(-50%, -50%);
		transform-origin: center center;
		will-change: transform;
	}

	.horizontal-track {
		display: flex;
		flex-direction: row;
		width: 200vw;
		height: 100vh;
		will-change: transform;
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { MotionPathPlugin } from "gsap/MotionPathPlugin";

	gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);

	// Check if simple scroll mode is enabled
	const isSimpleScroll = document.body.classList.contains('simple-scroll');

	// Only run animations if NOT in simple scroll mode
	if (!isSimpleScroll) {
		// Initial state for about and skills section elements (hidden and translated down)
		gsap.set(
			".about-number, .about-heading, .about-badge, .about-content > *",
			{
				opacity: 0,
				y: 40,
			},
		);

		gsap.set(".skills-number, .skills-heading, .skills-intro, .skill-row", {
			opacity: 0,
			y: 40,
		});

		// Master Horizontal Scroll Timeline
		const horizontalTl = gsap.timeline({
			scrollTrigger: {
				trigger: ".horizontal-scroll-container",
				start: "top top",
				end: "+=500%",
				pin: true,
				pinSpacing: true,
				scrub: 1,
				invalidateOnRefresh: true,
			},
		});

		// Glide the rotating brutalist star along the SVG dashed bezier curve
		horizontalTl.to(
			".flying-element",
			{
				motionPath: {
					path: "#flying-path",
					align: "#flying-path",
					autoRotate: false,
					alignOrigin: [0.5, 0.5],
				},
				rotation: 720,
				duration: 3.0,
				ease: "none",
			},
			0,
		);

		// 1. Fade up the about section contents
		horizontalTl
			.to(
				".about-number, .about-heading, .about-badge, .about-content > *",
				{
					opacity: 1,
					y: 0,
					duration: 0.8,
					stagger: 0.05,
					ease: "power2.out",
				},
				0,
			)
			// 2. Slide the skills section horizontally into view
			.to(
				".horizontal-track",
				{
					x: "-100vw",
					duration: 1.5,
					ease: "power2.inOut",
				},
				1.0,
			)
			// 3. Fade up the skills section contents
			.to(
				".skills-number, .skills-heading, .skills-intro, .skill-row",
				{
					opacity: 1,
					y: 0,
					duration: 0.8,
					stagger: 0.05,
					ease: "power2.out",
				},
				1.8,
			);
	}
</script>
